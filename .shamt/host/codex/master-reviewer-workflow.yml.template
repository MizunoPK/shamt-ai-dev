# master-reviewer-workflow.yml — @codex-driven master PR review pipeline
#
# MASTER REPO ONLY — copy this to .github/workflows/master-reviewer.yml on the
# master shamt-ai-dev repo. Do NOT deploy to child projects. Child regen scripts
# skip files in .shamt/host/codex/ that are not referenced in regen-codex-shims.sh.
#
# Triggers a Codex Cloud review task when a PR is labeled 'needs-shamt-review'.
# The cloud task loads the shamt-master-reviewer skill, checks separation-rule
# compliance, and posts a draft review comment.
#
# Cost note: Each @codex cloud task consumes API tokens. This workflow is
# label-gated (not auto-triggered) to manage costs on busy repos.
# Apply 'needs-shamt-review' only to PRs from child projects touching
# shared guide files.
#
# Prerequisites:
#   1. Codex Cloud enabled on this repo (openai.com/codex → project settings)
#   2. 'needs-shamt-review' label created in this repo
#   3. OPENAI_API_KEY secret set (or the Codex Cloud GitHub App handles auth)
#   4. GITHUB_TOKEN has pull-requests: write (provided automatically below)
#
# On task failure:
#   The workflow posts a "review task failed — retry with @codex review" comment
#   so the failure is visible on the PR rather than silent.

name: Shamt Master Reviewer

on:
  pull_request:
    types: [labeled]

permissions:
  contents: read
  pull-requests: write

jobs:
  review:
    name: Run shamt-master-reviewer via Codex Cloud
    runs-on: ubuntu-latest
    if: github.event.label.name == 'needs-shamt-review'

    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Post "review starting" comment
        uses: actions/github-script@v7
        with:
          script: |
            await github.rest.issues.createComment({
              owner: context.repo.owner,
              repo: context.repo.repo,
              issue_number: context.issue.number,
              body: "🔍 **Shamt Master Reviewer** — starting Codex Cloud review task...\n\n_This may take a few minutes. Results will be posted below._"
            });

      - name: Trigger Codex Cloud review task
        id: codex_review
        env:
          OPENAI_API_KEY: ${{ secrets.OPENAI_API_KEY }}
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          # Get the PR diff to pass to the Codex session
          PR_NUMBER="${{ github.event.pull_request.number }}"
          BASE_SHA="${{ github.event.pull_request.base.sha }}"
          HEAD_SHA="${{ github.event.pull_request.head.sha }}"

          DIFF=$(git diff "$BASE_SHA" "$HEAD_SHA" -- '.shamt/guides/**' '*.md' 2>/dev/null | head -c 32000)

          # Drive the Codex session with the shamt-master-reviewer skill
          # The skill is loaded from .agents/skills/shamt-master-reviewer/SKILL.md
          # (deployed by regen-codex-shims.sh on the runner)
          python3 - <<'PYEOF'
          import os, json, sys
          from openai import OpenAI

          client = OpenAI(api_key=os.environ["OPENAI_API_KEY"])
          diff = os.environ.get("DIFF", "(diff unavailable)")

          skill_path = os.path.join(os.environ.get("GITHUB_WORKSPACE", os.getcwd()), ".agents/skills/shamt-master-reviewer/SKILL.md")
          try:
              skill = open(skill_path).read()
          except FileNotFoundError:
              skill = "(shamt-master-reviewer skill not found on runner — check regen)"

          prompt = f"""You are running the shamt-master-reviewer skill on an incoming child PR.

          {skill[:4000]}

          ---

          PR diff (guide files and docs, up to 32KB):
          ```diff
          {diff[:28000]}
          ```

          Produce a structured review comment:
          1. Separation rule check — does any changed shared guide file contain project-specific content?
          2. Guide audit — are there consistency or correctness issues in the touched guides?
          3. Verdict — APPROVE / REQUEST_CHANGES / COMMENT with brief reasoning

          Format your output as a GitHub PR review comment (markdown).
          """

          response = client.chat.completions.create(
              model="o3",
              messages=[{"role": "user", "content": prompt}],
              timeout=240,
          )
          review = response.choices[0].message.content
          # Write to file for the next step
          with open("/tmp/review-output.md", "w") as f:
              f.write(review)
          print("Review generated successfully.")
          PYEOF

      - name: Post review comment
        if: success()
        uses: actions/github-script@v7
        with:
          script: |
            const fs = require('fs');
            const review = fs.readFileSync('/tmp/review-output.md', 'utf8');
            await github.rest.issues.createComment({
              owner: context.repo.owner,
              repo: context.repo.repo,
              issue_number: context.issue.number,
              body: `## 🤖 Shamt Master Reviewer\n\n${review}\n\n---\n_Generated by [master-reviewer-workflow.yml](../.shamt/host/codex/master-reviewer-workflow.yml.template) via Codex Cloud_`
            });

      - name: Post failure comment
        if: failure()
        uses: actions/github-script@v7
        with:
          script: |
            await github.rest.issues.createComment({
              owner: context.repo.owner,
              repo: context.repo.repo,
              issue_number: context.issue.number,
              body: "⚠️ **Shamt Master Reviewer** — review task failed (timeout, OOM, or network error).\n\nRetry by removing and re-applying the `needs-shamt-review` label, or run the review manually with `@codex review`."
            });
