{
  "__inputs": [
    {"name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus"},
    {"name": "DS_TEMPO", "label": "Tempo", "type": "datasource", "pluginId": "tempo"}
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "datasource", "id": "tempo", "name": "Tempo", "version": "1.0.0"}
  ],
  "title": "Shamt Overview",
  "uid": "shamt-overview",
  "description": "Request duration, token usage, and tool call counts by stage and persona",
  "tags": ["shamt"],
  "refresh": "30s",
  "time": {"from": "now-24h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "Active Stage",
      "type": "stat",
      "gridPos": {"x": 0, "y": 0, "w": 4, "h": 4},
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "expr": "label_replace(max by(shamt_stage) (shamt_session_active{shamt_stage!=\"\"}), \"stage\", \"$1\", \"shamt_stage\", \"(.*)\")",
        "legendFormat": "{{stage}}"
      }],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "name"}
    },
    {
      "id": 2,
      "title": "Tool Calls by Stage (24h)",
      "type": "barchart",
      "gridPos": {"x": 4, "y": 0, "w": 10, "h": 8},
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "expr": "sum by(shamt_stage) (increase(shamt_tool_calls_total[24h]))",
        "legendFormat": "{{shamt_stage}}"
      }],
      "fieldConfig": {"defaults": {"unit": "short"}},
      "options": {"xField": "shamt_stage", "stacking": "none"}
    },
    {
      "id": 3,
      "title": "Token Usage by Persona (24h)",
      "type": "piechart",
      "gridPos": {"x": 14, "y": 0, "w": 10, "h": 8},
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "expr": "sum by(shamt_persona) (increase(shamt_tokens_total[24h]))",
        "legendFormat": "{{shamt_persona}}"
      }],
      "fieldConfig": {"defaults": {"unit": "short"}},
      "options": {"pieType": "pie", "legend": {"displayMode": "table", "placement": "right"}}
    },
    {
      "id": 4,
      "title": "Span Duration by Stage (p50/p95/p99)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.50, sum by(le, shamt_stage) (rate(shamt_span_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{shamt_stage}}"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.95, sum by(le, shamt_stage) (rate(shamt_span_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{shamt_stage}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 5,
      "title": "Recent Shamt Traces",
      "type": "traces",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "targets": [{
        "datasource": {"type": "tempo", "uid": "${DS_TEMPO}"},
        "queryType": "nativeSearch",
        "serviceName": "shamt",
        "limit": 20
      }]
    }
  ],
  "schemaVersion": 38
}
