{
  "__inputs": [
    {"name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus"},
    {"name": "DS_TEMPO", "label": "Tempo", "type": "datasource", "pluginId": "tempo"}
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "datasource", "id": "tempo", "name": "Tempo", "version": "1.0.0"}
  ],
  "title": "Shamt Architect-Builder (S6)",
  "uid": "shamt-architect-builder",
  "description": "S6 builder execution duration, error rates, and model spend (CLI and Cloud variants)",
  "tags": ["shamt", "s6", "architect-builder"],
  "refresh": "30s",
  "time": {"from": "now-7d", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "Builder Success Rate",
      "type": "stat",
      "gridPos": {"x": 0, "y": 0, "w": 4, "h": 4},
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "expr": "sum(rate(shamt_builder_runs_total{status=\"success\"}[7d])) / sum(rate(shamt_builder_runs_total[7d]))",
        "legendFormat": "success rate"
      }],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "orientation": "auto",
        "textMode": "value",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {"steps": [
            {"color": "red", "value": 0},
            {"color": "yellow", "value": 0.8},
            {"color": "green", "value": 0.95}
          ]}
        }
      }
    },
    {
      "id": 2,
      "title": "Builder Execution Duration (p50 / p95)",
      "type": "timeseries",
      "gridPos": {"x": 4, "y": 0, "w": 10, "h": 8},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.50, sum by(le, shamt_variant) (rate(shamt_builder_duration_seconds_bucket[1h])))/60",
          "legendFormat": "p50 {{shamt_variant}}"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.95, sum by(le, shamt_variant) (rate(shamt_builder_duration_seconds_bucket[1h])))/60",
          "legendFormat": "p95 {{shamt_variant}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "m"}},
      "options": {"legend": {"displayMode": "table"}}
    },
    {
      "id": 3,
      "title": "Model Spend: Architect vs. Builder (tokens)",
      "type": "barchart",
      "gridPos": {"x": 14, "y": 0, "w": 10, "h": 8},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum(increase(shamt_tokens_total{shamt_persona=\"shamt-architect\"}[24h]))",
          "legendFormat": "architect"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum(increase(shamt_tokens_total{shamt_persona=\"shamt-builder\"}[24h]))",
          "legendFormat": "builder (CLI)"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum(increase(shamt_tokens_total{shamt_persona=\"shamt-s6-builder\"}[24h]))",
          "legendFormat": "builder (cloud)"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 4,
      "title": "Builder Error Breakdown",
      "type": "piechart",
      "gridPos": {"x": 0, "y": 8, "w": 8, "h": 8},
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "expr": "sum by(shamt_error_type) (increase(shamt_builder_errors_total[7d]))",
        "legendFormat": "{{shamt_error_type}}"
      }],
      "options": {"pieType": "pie", "legend": {"displayMode": "table", "placement": "right"}}
    },
    {
      "id": 5,
      "title": "Cloud vs. CLI Variant Runs",
      "type": "timeseries",
      "gridPos": {"x": 8, "y": 8, "w": 8, "h": 8},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum(rate(shamt_builder_runs_total{shamt_variant=\"cloud\"}[1d]))",
          "legendFormat": "cloud runs/day"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum(rate(shamt_builder_runs_total{shamt_variant=\"cli\"}[1d]))",
          "legendFormat": "CLI runs/day"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 6,
      "title": "Recent S6 Builder Traces",
      "type": "traces",
      "gridPos": {"x": 16, "y": 8, "w": 8, "h": 8},
      "targets": [{
        "datasource": {"type": "tempo", "uid": "${DS_TEMPO}"},
        "queryType": "nativeSearch",
        "serviceName": "shamt",
        "tags": "shamt.stage=S6",
        "limit": 15
      }]
    }
  ],
  "schemaVersion": 38
}
