# =============================================================================
# shamt-ai-dev — Master Repository Gitignore
# =============================================================================

# Claude Code local settings (machine-specific)
.claude/

# Audit outputs — local working files, never commit
# Each child project generates its own outputs during audits.
# Master's outputs/ dir is cleared on init (child starts fresh).
.shamt/guides/audit/outputs/

# Import diff files — transient, generated by import.sh/ps1
# Deleted after agent review per import_workflow.md Step 6.
.shamt/import_diff*.md

# Child-project operational files — not used in master, gitignored defensively
# shamt_master_path.conf would exist in a child project pointing to this repo
# last_sync.conf would exist in a child project tracking import history
.shamt/shamt_master_path.conf
.shamt/last_sync.conf
